# Optional path to an FFmpeg binary used by the contribution preview gateway.
# Native SRT is preferred; VLC can bridge SRT when this build lacks libsrt.
FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# Optional VLC binary used as an SRT-to-UDP bridge when FFmpeg was built
# without libsrt. VLC must include access_srt and access_output_srt modules.
VLC_PATH=/Applications/VLC.app/Contents/MacOS/VLC

# Four consecutive loopback UDP ports are reserved for multiview slots.
SRT_BRIDGE_UDP_BASE=12000

# The Edge Agent is loopback-only by default. Set this only inside a protected
# deployment network when another host must reach the agent.
HOST=127.0.0.1
