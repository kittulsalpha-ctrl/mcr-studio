AWS_REGION=us-east-1
MCR_ORCHESTRATOR_URL=http://127.0.0.1:8080
TELEMETRY_INGEST_TOKEN=replace-with-a-long-random-token
TELEMETRY_COLLECTOR_NAME=client-aws-telemetry-worker
TELEMETRY_POLL_SECONDS=60

# Configure only resources the client has deployed.
MEDIALIVE_CHANNEL_ID=
MEDIACONNECT_FLOW_ARN=
DIRECT_CONNECT_VIF_ID=
# Optional: configure when the delivery architecture uses AWS MediaPackage.
# MediaPackage telemetry can also be posted by a client-specific collector.
MEDIAPACKAGE_CHANNEL_ID=
CLOUDFRONT_DISTRIBUTION_ID=
CONTRIBUTION_ENCODER_NAME=
